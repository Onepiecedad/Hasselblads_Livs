# WordPress admin – proxy through Netlify function to WordPress backend
/wp-login.php  /.netlify/functions/wordpress-proxy/wp-login.php  200!
/wp-admin/*    /.netlify/functions/wordpress-proxy/wp-admin/:splat  200!
/wp-json/*     /.netlify/functions/wordpress-proxy/wp-json/:splat  200!

# WooCommerce final checkout and cart - proxy to WordPress
/wp-content/*  /.netlify/functions/wordpress-proxy/wp-content/:splat  200!
/wp-includes/* /.netlify/functions/wordpress-proxy/wp-includes/:splat 200!
# Order confirmation must use /kassan/ (WP redirects /kassa/order-received → /kassan/ causing a loop)
/betalning/order-received/*  /.netlify/functions/wordpress-proxy/kassan/order-received/:splat  200!
/betalning       /.netlify/functions/wordpress-proxy/kassa            200!
/betalning/      /.netlify/functions/wordpress-proxy/kassa/           200!
/betalning/*     /.netlify/functions/wordpress-proxy/kassa/:splat     200!
/kassan          /betalning                                            301
/kassan/*        /betalning/:splat                                     301
/varukorg    /.netlify/functions/wordpress-proxy/varukorg         200!
/varukorg/   /.netlify/functions/wordpress-proxy/varukorg/        200!
/varukorg/*  /.netlify/functions/wordpress-proxy/varukorg/:splat  200!
/wc-ajax/*   /.netlify/functions/wordpress-proxy/wc-ajax/:splat   200!

# WooCommerce customer account page - proxy to WordPress
/mitt-konto      /.netlify/functions/wordpress-proxy/mitt-konto         200!
/mitt-konto/     /.netlify/functions/wordpress-proxy/mitt-konto/        200!
/mitt-konto/*    /.netlify/functions/wordpress-proxy/mitt-konto/:splat  200!
/my-account      /.netlify/functions/wordpress-proxy/my-account         200!
/my-account/     /.netlify/functions/wordpress-proxy/my-account/        200!
/my-account/*    /.netlify/functions/wordpress-proxy/my-account/:splat  200!

# URL redirects for Swedish characters
/sasong /säsong 301
/kundtjanst /kundservice 301
/checkout /betalning 301

# SPA fallback - MUST be last!
/*    /index.html   200
